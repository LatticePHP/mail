{
    "name": "lattice/mail",
    "description": "Mail sending and transport abstraction for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "mail",
        "email",
        "smtp",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/mail"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Mail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Mail\\Tests\\": "tests/"
        }
    }
}
